# Cursor x ALT+TAB Hackathon — ortam değişkenleri şablonu
# Gerçek değerleri .env dosyasına koy (.env commit edilmez)
# Sonra: bash scripts/sync-env.sh  (web/mobile .env.local senkronu)

# --- Google (tek Cloud projesi / tek key yeterli) ---
# Backend (Render): Routes API + Street View Static — server-only, istemciye gitmez
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
# Opsiyonel alias; bos birakilirsa GOOGLE_MAPS_API_KEY kullanilir
GOOGLE_STREET_VIEW_API_KEY=your_google_maps_api_key

# Web harita (Maps JavaScript API) — tarayicida gorunur; Vercel Production'a da ekle
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Mobil harita (Maps SDK Android/iOS) — Expo .env.local / EAS
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google Cloud'da acik olmali: Routes API, Maps JavaScript API,
# Maps SDK for Android/iOS, Street View Static API

# --- Deploy / otomasyon ---
RENDER_API_KEY=your_render_api_key
VERCEL_TOKEN=your_vercel_token

# --- Hugging Face (en az biri) ---
HUGGINGFACE_API_KEY=your_huggingface_api_key
HF_TOKEN=your_huggingface_token

# --- Modal (yalnizca anonimlestirilmis veriyle egitim) ---
MODAL_TOKEN_ID=your_modal_token_id
MODAL_TOKEN_SECRET=your_modal_token_secret

# --- Go backend (Render) ---
# Fixture-only demo icin bos birakilabilir; production hedefi Postgres
DATABASE_URL=postgres://user:password@host:5432/db
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://web-lake-phi-31.vercel.app

# --- Next.js web ---
# Local dev: http://localhost:8080
# Canli demo: https://omnisight-api-70gd.onrender.com
NEXT_PUBLIC_API_BASE_URL=https://omnisight-api-70gd.onrender.com
CURSOR_API_KEY=your_cursor_api_key
CURSOR_MODEL=composer-2

# --- Expo mobil ---
EXPO_PUBLIC_API_BASE_URL=https://omnisight-api-70gd.onrender.com
EXPO_PUBLIC_DEMO_OFFER_NAME=Komagene-style YolDost Demo Cafe
EXPO_PUBLIC_DEMO_OFFER_PARTNER=Demo Cafe Partner
EXPO_PUBLIC_DEMO_OFFER_AREA=Gungoren demo point
EXPO_PUBLIC_DEMO_OFFER_LATITUDE=41.010259
EXPO_PUBLIC_DEMO_OFFER_LONGITUDE=28.874899
EXPO_PUBLIC_DEMO_OFFER_RADIUS_METERS=150
EXPO_PUBLIC_DEMO_OFFER_TEXT=Demo partner offer: take a short active-route break nearby. Sponsorship never changes route scores.
